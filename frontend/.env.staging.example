# Staging build env. Copy to `.env.staging` (gitignored) and fill in.
# Build staging explicitly with:  vite build --mode staging
# All values are INLINED into the bundle at build time — they are public.

# --- Auth0 (staging SPA application) -------------------------------------
# Ideally a separate Auth0 app/tenant from prod. Callback/Logout/Web Origins
# must include https://staging.sketchable.jorio.dev.
VITE_AUTH0_DOMAIN=your-staging-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-staging-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.sketchable

# --- Sketchable API (staging) --------------------------------------------
VITE_API_BASE_URL=https://api-staging.sketchable.jorio.dev

VITE_AUTH0_REDIRECT_URI=https://staging.sketchable.jorio.dev

# --- Web Push (staging VAPID public key) ---------------------------------
VITE_VAPID_PUBLIC_KEY=
