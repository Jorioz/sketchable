# Production build env. Copy to `.env.production` (gitignored) and fill in.
# Vite auto-loads `.env.production` when you run `vite build` (mode=production).
# All values are INLINED into the bundle at build time — they are public.

# --- Auth0 (PRODUCTION SPA application) ----------------------------------
# Use a dedicated prod Auth0 application, NOT your dev one. Its Allowed
# Callback/Logout URLs and Web Origins must be set to https://sketchable.jorio.dev.
VITE_AUTH0_DOMAIN=your-prod-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-prod-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.sketchable

# --- Sketchable API (production) -----------------------------------------
# Custom domain fronting the HTTP API (see backend/lambda template Domain).
VITE_API_BASE_URL=https://api.sketchable.jorio.dev

# Production callback origin (exact match required in Auth0).
VITE_AUTH0_REDIRECT_URI=https://sketchable.jorio.dev

# --- Web Push (production VAPID public key) -------------------------------
# Must pair with the VapidPrivateKey stored in SSM for the prod backend.
VITE_VAPID_PUBLIC_KEY=
