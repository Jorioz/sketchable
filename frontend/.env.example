# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Vite only exposes vars prefixed with VITE_, and inlines them at build time.

# --- Auth0 (Single Page Application) -------------------------------------
# From your Auth0 dashboard → Applications → your SPA → Settings.
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
# REQUIRED — the Auth0 API identifier (audience). Without it Auth0 returns an
# opaque access token instead of a JWT and the backend can't verify it. Create
# an API in Auth0 (APIs → Create API) and use its Identifier here. Must match
# the backend's AUTH0_AUDIENCE.
VITE_AUTH0_AUDIENCE=https://api.sketchable

# --- Sketchable API ------------------------------------------------------
# The deployed HTTP API base URL (SAM stack output `ApiBaseUrl`).
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-2.amazonaws.com

# --- Auth0 redirect override (optional) ----------------------------------
# Leave blank to use the current browser origin. Set this when you need a
# specific callback URL, for example:
#   https://localhost:5173
#   https://192.168.1.50:5173
# Must be added to Auth0 Allowed Callback URLs exactly.
VITE_AUTH0_REDIRECT_URI=

# --- Web Push (notifications) --------------------------------------------
# Base64url VAPID *public* key. Must pair with the backend's VapidPrivateKey.
# Generate the keypair once:  pip install py-vapid && vapid --gen
# then print this value with:  vapid --applicationServerKey
# Leave blank to hide the notifications UI (push disabled). On iOS, push only
# works for the app installed to the Home Screen (iOS 16.4+).
VITE_VAPID_PUBLIC_KEY=
