{
    "mcpServers": {
        "shadcn": {
            "command": "npx",
            "args": ["shadcn@latest", "mcp"]
        },
        "aws-mcp": {
            "command": "uvx",
            "args": [
                "mcp-proxy-for-aws==1.6.2",
                "https://aws-mcp.us-east-1.api.aws/mcp",
                "--metadata",
                "AWS_REGION=us-west-2"
            ]
        }
    }
}
