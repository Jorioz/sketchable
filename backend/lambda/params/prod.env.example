# Non-secret CloudFormation parameters for the PRODUCTION backend stack.
# Copy to `prod.env` (gitignored) and fill in. Secrets are NOT here — they come
# from SSM at deploy time (see samconfig.toml.example). KEY=VALUE, no quotes.
BucketName=sketchable-s3
Auth0Domain=your-prod-tenant.us.auth0.com
Auth0Audience=https://api.sketchable
AllowedOrigin=https://sketchable.jorio.dev
Auth0MgmtClientId=your-prod-m2m-client-id
VapidSubject=mailto:you@example.com
ApiDomainName=api.sketchable.jorio.dev
ApiCertificateArn=arn:aws:acm:us-east-2:ACCOUNT_ID:certificate/REPLACE_ME
