# Non-secret CloudFormation parameters for the STAGING backend stack
# (sketchable-staging). Copy to `staging.env` (gitignored) and fill in. Secrets
# come from SSM. Staging gets its OWN isolated sketch bucket + CloudFront, its
# own Lambda name, and no WAF — so it never touches prod resources.
BucketName=sketchable-s3-staging
Auth0Domain=your-tenant.us.auth0.com
Auth0Audience=https://api.sketchable/
AllowedOrigin=https://staging.sketchable.jorio.dev
Auth0MgmtClientId=your-m2m-client-id
VapidSubject=mailto:you@example.com
ApiDomainName=api-staging.sketchable.jorio.dev
ApiCertificateArn=arn:aws:acm:us-east-2:ACCOUNT_ID:certificate/STAGING_API_CERT
# Per-env resource names/config (override prod defaults so nothing collides):
FunctionName=sketchable-api-staging
OacName=oac-sketchable-s3-staging
WebACLId=
PriceClass=PriceClass_100
