# Non-secret CloudFormation parameters for the STAGING backend stack.
# Copy to `staging.env` (gitignored) and fill in. Secrets come from SSM.
BucketName=sketchable-s3-staging
Auth0Domain=your-staging-tenant.us.auth0.com
Auth0Audience=https://api.sketchable
AllowedOrigin=https://staging.sketchable.jorio.dev
Auth0MgmtClientId=your-staging-m2m-client-id
VapidSubject=mailto:you@example.com
ApiDomainName=api-staging.sketchable.jorio.dev
ApiCertificateArn=arn:aws:acm:us-east-2:ACCOUNT_ID:certificate/REPLACE_ME
